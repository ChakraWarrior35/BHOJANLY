# Sample environment variables (do NOT commit secrets)
# Copy this to a real env file or set these values in Render dashboard

# Django
SECRET_KEY=your-very-secret-key
DEBUG=false
ALLOWED_HOSTS=your-app.onrender.com

# Database (Render provides this for managed Postgres)
DATABASE_URL=postgres://user:password@host:port/dbname

# Optional
SECURE_SSL_REDIRECT=true
